# ============================================================
#  Skinão Motos — o que NUNCA vai para o repositório
# ============================================================

# Banco local SQLite (contém dados reais de clientes e senha do admin)
/data/*.sqlite
/data/*.sqlite3
/data/*.db
/data/import/

# Dados exportados para produção — contêm CPF de clientes e hash de senha.
# Gere localmente com: php scripts/exportar-mysql.php
/sql/dados-producao.sql

# Credenciais da hospedagem (criado no servidor a partir do .example)
/includes/config.local.php

# Fotos e documentos enviados pelo painel (vão por uploads-fotos.zip).
# A pasta INTEIRA fica fora do repo: no servidor, public_html/uploads é um
# symlink para ../uploads_data — se uploads/ existisse no repo, o auto-deploy
# da Hostinger recriaria a pasta real por cima do symlink (ver DEPLOY.md).
/uploads/

# Pacotes de deploy (gerados por scripts/empacotar-deploy.ps1)
*.zip

# Ferramentas locais de desenvolvimento
# (.claude/launch.json é versionado — define como subir o servidor de dev)
/.claude/*
!/.claude/launch.json
/.vscode/

# Lixo de sistema e temporários
Thumbs.db
.DS_Store
*.log
*.tmp
*.bak
