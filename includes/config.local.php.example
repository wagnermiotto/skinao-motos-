// ---- Banco de dados MySQL da hospedagem ----
define('DB_DRIVER', 'mysql');

define('DB_HOST', 'localhost');           // normalmente 'localhost' no cPanel
define('DB_NAME', 'usuario_skinao');      // nome do banco criado no painel
define('DB_USER', 'usuario_skinao');      // usuário do banco
define('DB_PASS', 'SUA_SENHA_AQUI');      // senha do banco

